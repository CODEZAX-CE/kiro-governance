{
  "name": "construct-developer",
  "description": "CDK Construct Developer - Creates and maintains reusable L3 CDK constructs in infra/constructs/ for the project.",
  "prompt": "file://./construct-developer/prompt.md",
  "welcomeMessage": "Construct developer ready. Which construct are we working on?",
  "keyboardShortcut": "ctrl+shift+c",
  "tools": ["read", "write", "shell", "grep", "glob", "code", "aws", "knowledge", "todo"],
  "allowedTools": ["read", "grep", "glob", "code", "knowledge"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["./infra/**", "./docs/**"]
    },
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": [
        "git commit.*",
        "git push.*",
        "git pull.*",
        "git merge.*",
        "git rebase.*",
        "git cherry-pick.*",
        "git reset.*",
        "git checkout -b.*",
        "git branch -d.*",
        "git tag.*",
        "git stash.*",
        "git add.*",
        "git rm.*",
        "git mv.*",
        "aws .* create-.*",
        "aws .* delete-.*",
        "aws .* update-.*",
        "aws .* put-.*",
        "aws .* modify-.*",
        "aws .* terminate-.*",
        "aws .* stop-.*",
        "aws .* start-.*",
        "aws .* reboot-.*",
        "aws .* remove-.*",
        "aws .* attach-.*",
        "aws .* detach-.*",
        "aws .* enable-.*",
        "aws .* disable-.*",
        "aws .* associate-.*",
        "aws .* disassociate-.*",
        "aws .* register-.*",
        "aws .* deregister-.*",
        "aws .* apply-.*",
        "aws .* invoke-.*",
        "aws .* run-.*",
        "aws .* execute-.*",
        "aws .* import-.*",
        "aws .* export-.*",
        "aws .* upload-.*",
        "aws .* copy-.*",
        "aws .* move-.*",
        "aws .* restore-.*",
        "aws .* revoke-.*",
        "aws .* cancel-.*",
        "aws .* reset-.*",
        "aws .* set-.*",
        "aws .* add-.*",
        "aws .* batch-write-.*",
        "aws .* transact-write-.*"
      ]
    },
    "aws": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://.kiro/steering/product.md",
    "file://.kiro/steering/cdk-constructs-standards.md",
    "skill://.kiro/skills/construct-developer/*/SKILL.md",
    "file://docs/code-structure.md"
  ],
  "mcpServers": {
    "awslabs.cdk-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.cdk-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    }
  },
  "includeMcpJson": false,
  "model": "claude-haiku-4.5"
}
